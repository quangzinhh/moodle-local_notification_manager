<div class="local-notification-dashboard-tab" id="local-notification-dashboard-tab">
    <style>
        .nm-dashboard-container {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
            margin-top: 20px;
        }
        .nm-dashboard-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 2rem;
        }
        .nm-card {
            background: #fff;
            border-radius: 12px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.05);
            padding: 24px;
            margin-bottom: 24px;
            border: none;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }
        .nm-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(0,0,0,0.08);
        }
        .nm-card-title {
            font-size: 1.25rem;
            font-weight: 600;
            color: #2c3e50;
            margin-bottom: 1.5rem;
            display: flex;
            align-items: center;
        }
        
        /* Engagement Circular Chart */
        .nm-engagement-wrapper {
            display: flex;
            align-items: center;
            justify-content: space-around;
            flex-wrap: wrap;
        }
        .nm-circle-chart {
            position: relative;
            width: 150px;
            height: 150px;
            border-radius: 50%;
            background: conic-gradient(#e74c3c {{engagement.chart_arc}}deg, #ecf0f1 0deg);
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .nm-circle-inner {
            width: 120px;
            height: 120px;
            background: #fff;
            border-radius: 50%;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            box-shadow: inset 0 2px 10px rgba(0,0,0,0.05);
        }
        .nm-circle-value {
            font-size: 2rem;
            font-weight: 700;
            color: #e74c3c;
            line-height: 1;
        }
        .nm-circle-label {
            font-size: 0.8rem;
            color: #7f8c8d;
            text-transform: uppercase;
            font-weight: 600;
            margin-top: 4px;
        }
        .nm-stat-box {
            text-align: center;
            padding: 15px 25px;
            border-radius: 8px;
            background: #f8f9fa;
            min-width: 120px;
        }
        .nm-stat-value {
            font-size: 1.8rem;
            font-weight: 700;
            color: #2c3e50;
        }
        .nm-stat-label {
            font-size: 0.9rem;
            color: #95a5a6;
            margin-top: 5px;
        }
        .nm-stat-read { color: #2ecc71; }
        .nm-stat-unread { color: #e74c3c; }

        /* Top Users List */
        .nm-user-list {
            list-style: none;
            padding: 0;
            margin: 0;
        }
        .nm-user-item {
            display: flex;
            align-items: center;
            padding: 12px 0;
            border-bottom: 1px solid #edf2f7;
        }
        .nm-user-item:last-child {
            border-bottom: none;
        }
        .nm-user-avatar {
            width: 45px;
            height: 45px;
            border-radius: 50%;
            margin-right: 15px;
            object-fit: cover;
            border: 2px solid #e2e8f0;
        }
        .nm-user-info {
            flex-grow: 1;
        }
        .nm-user-name {
            font-weight: 600;
            color: #2d3748;
            margin: 0;
            font-size: 1rem;
        }
        .nm-user-badge {
            background: #3498db;
            color: white;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.85rem;
            font-weight: 600;
        }

        /* Type Progress Bars */
        .nm-type-item {
            margin-bottom: 16px;
        }
        .nm-type-header {
            display: flex;
            justify-content: space-between;
            margin-bottom: 6px;
            font-size: 0.95rem;
            color: #4a5568;
            font-weight: 500;
        }
        .nm-type-bar-bg {
            height: 8px;
            background: #edf2f7;
            border-radius: 4px;
            overflow: hidden;
        }
        .nm-type-bar {
            height: 100%;
            border-radius: 4px;
            transition: width 1s ease-out;
        }
    </style>

    <div class="nm-dashboard-container">
        
        <div class="nm-dashboard-header">
            <h2 class="mb-0">{{str.tab_dashboard}}</h2>
            <div>
                <form id="nm-timerange-form" method="get" action="index.php" class="form-inline">
                    <input type="hidden" name="tab" value="dashboard">
                    <label for="timerange" class="mr-2 font-weight-bold">{{str.time_range}}:</label>
                    <select name="timerange" id="timerange" class="form-control custom-select" onchange="document.getElementById('nm-timerange-form').submit();">
                        <option value="7" {{#is_7}}selected{{/is_7}}>{{str.time_7_days}}</option>
                        <option value="30" {{#is_30}}selected{{/is_30}}>{{str.time_30_days}}</option>
                        <option value="90" {{#is_90}}selected{{/is_90}}>{{str.time_90_days}}</option>
                        <option value="all" {{#is_all}}selected{{/is_all}}>{{str.time_all}}</option>
                    </select>
                </form>
            </div>
        </div>

        <div class="row">
            <div class="col-12">
                <div class="nm-card">
                    <h3 class="nm-card-title">
                        <i class="fa fa-pie-chart mr-2 text-primary"></i> {{str.analytic_engagement}}
                    </h3>
                    <div class="nm-engagement-wrapper">
                        
                        <div class="nm-stat-box">
                            <div class="nm-stat-value">{{engagement.total}}</div>
                            <div class="nm-stat-label">{{str.analytic_total}}</div>
                        </div>

                        <div class="nm-circle-chart">
                            <div class="nm-circle-inner">
                                <div class="nm-circle-value">{{engagement.unread_rate}}%</div>
                                <div class="nm-circle-label">{{str.analytic_unread_rate}}</div>
                            </div>
                        </div>

                        <div class="nm-stat-box">
                            <div class="nm-stat-value nm-stat-read">{{engagement.read}}</div>
                            <div class="nm-stat-label">{{str.analytic_read}}</div>
                        </div>

                        <div class="nm-stat-box">
                            <div class="nm-stat-value nm-stat-unread">{{engagement.unread}}</div>
                            <div class="nm-stat-label">{{str.analytic_unread}}</div>
                        </div>

                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6">
                <div class="nm-card h-100">
                    <h3 class="nm-card-title">
                        <i class="fa fa-users mr-2 text-info"></i> {{str.analytic_top_users}}
                    </h3>
                    {{#has_topusers}}
                        <ul class="nm-user-list">
                            {{#topusers}}
                                <li class="nm-user-item">
                                    <img src="{{profileimageurl}}" alt="{{fullname}}" class="nm-user-avatar">
                                    <div class="nm-user-info">
                                        <h4 class="nm-user-name">{{fullname}}</h4>
                                    </div>
                                    <div class="nm-user-badge">
                                        {{count}}
                                    </div>
                                </li>
                            {{/topusers}}
                        </ul>
                    {{/has_topusers}}
                    {{^has_topusers}}
                        <p class="text-muted">No users found for the selected time range.</p>
                    {{/has_topusers}}
                </div>
            </div>

            <div class="col-md-6">
                <div class="nm-card h-100">
                    <h3 class="nm-card-title">
                        <i class="fa fa-bar-chart mr-2 text-success"></i> {{str.analytic_popular_types}}
                    </h3>
                    {{#has_populartypes}}
                        <div class="nm-type-list mt-3">
                            {{#populartypes}}
                                <div class="nm-type-item">
                                    <div class="nm-type-header">
                                        <span>{{component}}</span>
                                        <span class="font-weight-bold">{{count}}</span>
                                    </div>
                                    <div class="nm-type-bar-bg">
                                        <div class="nm-type-bar" style="width: {{percent}}%; background-color: {{color}};"></div>
                                    </div>
                                </div>
                            {{/populartypes}}
                        </div>
                    {{/has_populartypes}}
                     {{^has_populartypes}}
                        <p class="text-muted">No notification types found.</p>
                    {{/has_populartypes}}
                </div>
            </div>
        </div>

    </div>
</div>
